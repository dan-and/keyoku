{
  "name": "@keyoku/openclaw",
  "version": "1.3.0",
  "description": "Keyoku memory plugin for OpenClaw — persistent memory, heartbeat enhancement, and scheduling",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "keyoku-init": "bin/init.js"
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@keyoku/memory": "1.2.14",
    "@keyoku/types": "1.2.14",
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ],
    "skills": [
      "skills/keyoku-memory"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
